{
  "name": "@iskl/dev-journal",
  "version": "0.2.0",
  "description": "An Agent Skill that generates structured developer journals (modification summary, future-reader guide, collaborator-facing API notes, and a self-review) to <project>/.journal after a coding session. Cross-platform: installs into Claude Code, Cursor, Gemini CLI, Codex CLI, OpenCode, Copilot via a single CLI.",
  "type": "module",
  "bin": {
    "dev-journal": "bin/install.mjs"
  },
  "files": [
    "skills",
    "bin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "changeset": "changeset",
    "version": "changeset version",
    "release:tag": "node bin/release-tag.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agent-skill",
    "agentskills.io",
    "claude-code",
    "cursor",
    "gemini-cli",
    "codex-cli",
    "skill",
    "journal",
    "dev-journal",
    "changelog",
    "code-review"
  ],
  "author": "iskl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sklme/skill_dev_journal.git"
  },
  "homepage": "https://github.com/sklme/skill_dev_journal#readme",
  "bugs": {
    "url": "https://github.com/sklme/skill_dev_journal/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0"
  }
}
